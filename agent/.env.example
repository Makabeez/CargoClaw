# ============================================================
#  CargoClaw — environment template. Copy to .env (gitignored).
#  NEVER commit real values. Store the Circle recovery file
#  OUTSIDE this repo.
# ============================================================

# ---- Arc Testnet ----
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# USDC ERC-20 interface on Arc (6 decimals). Also the native gas asset.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ---- Circle Developer-Controlled Wallets ----
# From https://console.circle.com  (format: PREFIX:ID:SECRET)
CIRCLE_API_KEY=
# 32-byte hex entity secret you generated + registered. NEVER commit.
CIRCLE_ENTITY_SECRET=
# Wallet ids printed by `npm run setup`
CIRCLE_AGENT_WALLET_ID=
CIRCLE_BUYER_WALLET_ID=

# ---- Contract ----
# Deploy CargoEscrow(USDC_ADDRESS, AGENT_WALLET_ADDRESS); paste the result here.
ESCROW_CONTRACT_ADDRESS=

# ---- Deploy only (Foundry) ----
# One-time throwaway key funded with Arc USDC for gas. NOT the agent key.
DEPLOYER_PRIVATE_KEY=
# The agent's Circle wallet ADDRESS (becomes the on-chain arbiter).
AGENT_WALLET_ADDRESS=

# ---- Autonomous decision engine (optional; falls back to deterministic rules) ----
# OpenAI-compatible endpoint, e.g. your local LiteLLM router on :4000
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=agent-loop

# ---- Server ----
PORT=3000
CORS_ORIGIN=*
